# Studify — Environment Variables
# ─────────────────────────────────────────────────────────────────
# SERVER-SIDE ONLY — set these as Supabase Edge Function secrets:
#   Supabase Dashboard → Project Settings → Edge Functions → Secrets
#
# NEVER paste these into config.js or index.html — they must stay server-side.

ANTHROPIC_API_KEY=sk-ant-...
SONAUTO_API_KEY=...
SUPABASE_SERVICE_ROLE_KEY=...

# ─────────────────────────────────────────────────────────────────
# BROWSER-SAFE — also copy these two into config.js:
#   Supabase Dashboard → Project Settings → API

SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=...
